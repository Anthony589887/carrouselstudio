# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
# CONVEX_DEPLOY_KEY required for Vercel build (from Convex dashboard → Settings → Deploy Keys)
CONVEX_DEPLOY_KEY=

# Gemini API (also set on Convex env via `convex env set GEMINI_API_KEY`)
GEMINI_API_KEY=

# Auth — Clerk (multi-account, invite-only)
# Next.js / Vercel:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
# Convex (set via `convex env set ...`, NOT in Vercel):
# CLERK_JWT_ISSUER_DOMAIN: the Clerk JWT issuer (Frontend API URL of the "convex" template)
# ADMIN_EMAILS: comma-separated emails bootstrapped as role "admin" on first sign-in
CLERK_JWT_ISSUER_DOMAIN=
ADMIN_EMAILS=

# Shared secret guarding /api/postprocess (server↔server only).
# Set the SAME value on: Convex (`convex env set POSTPROCESS_SECRET ...`, dev + prod)
# AND Next/Vercel. The route fails OPEN if it's unset on the Next side.
POSTPROCESS_SECRET=
