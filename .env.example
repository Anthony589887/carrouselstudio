# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
# CONVEX_DEPLOY_KEY required for Vercel build (from Convex dashboard → Settings → Deploy Keys)
CONVEX_DEPLOY_KEY=

# Gemini API (also set on Convex env via `convex env set GEMINI_API_KEY`)
GEMINI_API_KEY=

# Auth (Vercel deploy)
# AUTH_PASSWORD: what you type at /login
# AUTH_TOKEN_VALUE: opaque random UUID stored in the cookie (not the password itself)
AUTH_PASSWORD=
AUTH_TOKEN_VALUE=
